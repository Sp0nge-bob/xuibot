# === Telegram Bot ===
BOT_TOKEN=123456789:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BOT_ADMINS=123456789          # Твой Telegram ID (или несколько через запятую: 123,456)

# === Platega ===
PLATEGA_MERCHANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PLATEGA_SECRET=your_very_long_secret_key_from_platega
PLATEGA_BASE_URL=https://app.platega.io
# ID способов оплаты (уточните у менеджера Platega)
PLATEGA_SBP_METHOD=2
PLATEGA_CRYPTO_METHOD=13
# URL редиректа после оплаты (по умолчанию — ссылка на бота)
# PLATEGA_RETURN_URL=https://t.me/your_bot
# PLATEGA_FAILED_URL=https://t.me/your_bot

# === 3x-ui (подключайся ТОЛЬКО к главной панели) ===
# Базовый URL панели со secret path (БЕЗ /panel/ в конце — py3xui добавляет его сам)
XUI_HOST=https://cdn.example.com/hjksfhbjkdsbfjkkj/
# API Token из главной панели (Settings → API Token → Generate)
# Токен ты положил в grokerrorreports/api.txt
XUI_TOKEN=CdxEKFFPr8zgCQrUsNs4PQr1vYiG5iwbOlAGRu4B7ql4z6JP
# Если используешь токен — username/password можно не указывать
# XUI_USERNAME=admin
# XUI_PASSWORD=...

# Подписка — точно как у тебя настроена на главной панели (с маскировкой)
# У тебя формат: https://example.com/api/v4/GET/{sub_id}
# Укажи базу до {sub_id} (с trailing slash если нужно)
SUBSCRIPTION_BASE_URL=https://your-sub-domain.com/api/v4/GET/

# Инбаунды, которые попадут в подписку каждого покупателя
# Перечисли через запятую ID тех инбаундов (с главной + нод), которые должны быть в одной подписке.
# Пример: 12,45,67   (по одному с каждой ноды)
DEFAULT_SUBSCRIPTION_INBOUNDS=12,45,67

# Группа клиентов 3x-ui (v3.2+) — все tg* клиенты бота
XUI_CLIENT_GROUP=telegram-bot

# Фоллбэк на случай, если список выше пустой
DEFAULT_INBOUND_ID=1

# === Webhook для Platega (обязательно HTTPS в продакшене) ===
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080
WEBHOOK_PATH=/platega-webhook
# Публичный URL, который вы укажете в настройках Callback в ЛК Platega
PUBLIC_WEBHOOK_URL=https://example.com/platega-webhook

# === Дополнительно ===
LOG_LEVEL=INFO
# Файлы логов по сессиям (каждый перезапуск — новый файл, хранится 5 последних)
LOG_DIR=data/logs
LOG_SESSION_RETAIN=5
# Защита от двойных нажатий (параллельные callback / сообщения)
BOT_ACTION_LOCK_ENABLED=true
BOT_ACTION_DEBOUNCE_SEC=0.5
# Для локального теста на Windows лучше использовать polling (не нужно открывать порт наружу)
USE_POLLING=true

# === ТЕСТОВЫЙ РЕЖИМ (самое важное сейчас) ===
# TEST_MODE=true  → симулятор Platega: превью API-запроса, выбор сценария ответа.
# Это позволяет тебе полностью протестировать бота и показать менеджеру Platega.
# Когда подключишь Platega — поставь false и заполни реальные данные ниже.
TEST_MODE=true
