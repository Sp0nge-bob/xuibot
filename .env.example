# =============================================================================
# VPN Platega Bot — пример конфигурации
# Скопируйте:  copy .env.example .env  (Windows)  |  cp .env.example .env  (Linux)
# Полная документация: docs/README.md
# =============================================================================

# --- Telegram ---
BOT_TOKEN=123456789:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Telegram user ID админов (через запятую или JSON-массив)
BOT_ADMINS=123456789

# --- Platega (обязательно в продакшене) ---
PLATEGA_MERCHANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PLATEGA_SECRET=your_platega_secret_key
PLATEGA_BASE_URL=https://app.platega.io
# ID способов оплаты — уточните у менеджера Platega (docs.platega.io)
PLATEGA_SBP_METHOD=2
PLATEGA_ERIP_METHOD=3
PLATEGA_CARD_METHOD=11
PLATEGA_INTL_METHOD=12
PLATEGA_CRYPTO_METHOD=13
# Редирект после оплаты (по умолчанию — ссылка на бота)
# PLATEGA_RETURN_URL=https://t.me/your_bot
# PLATEGA_FAILED_URL=https://t.me/your_bot

# --- 3x-ui (главная панель) ---
# Базовый HTTPS URL со secret path, БЕЗ /panel/ в конце
# Пример: https://panel.example.com/your-secret-path/
XUI_HOST=https://panel.example.com/your-secret-path/
# API Token (Settings → API Token) — предпочтительно
XUI_TOKEN=your_xui_api_token
# Или логин/пароль (если без токена):
# XUI_USERNAME=admin
# XUI_PASSWORD=your_password
DEFAULT_INBOUND_ID=1

# Ссылка на подписку (маскировка nginx). База до {sub_id}:
# Пример: https://sub.example.com/api/v4/GET/
SUBSCRIPTION_BASE_URL=https://sub.example.com/api/v4/GET/

# Happ: шифрование ссылки подписки — none | crypt4_local | crypt5_api
# HAPP_CRYPTO_MODE=crypt4_local

# ID инбаундов в подписке (главная + ноды), через запятую
DEFAULT_SUBSCRIPTION_INBOUNDS=12,45,67

# Группа клиентов 3x-ui v3.2+
XUI_CLIENT_GROUP=telegram-bot

# --- Webhook Platega (HTTPS в продакшене) ---
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080
WEBHOOK_PATH=/platega-webhook
# Публичный URL для Callback в ЛК Platega (должен совпадать с WEBHOOK_PATH)
PUBLIC_WEBHOOK_URL=https://your-domain.com/platega-webhook

# --- Производительность (1000+ подписок) ---
XUI_PANEL_CONCURRENCY=5
XUI_INBOUND_CACHE_TTL=180
XUI_REQUEST_DELAY_MS=20
XUI_SECONDARY_SYNC_WORKERS=3
XUI_SECONDARY_SYNC_QUEUE_SIZE=500
XUI_EMAIL_LIST_CACHE_TTL=120
FULL_SYNC_INTERVAL_HOURS=24
SUBSCRIPTION_SYNC_DEBOUNCE_SEC=60
WEBHOOK_RATE_LIMIT_PER_MIN=120
WEBHOOK_IDEMPOTENCY_TTL_SEC=300
FULFILLMENT_QUEUE_WORKERS=2
FULFILLMENT_QUEUE_MAX_SIZE=200
STALE_PENDING_ORDER_HOURS=48

# --- Логирование ---
LOG_LEVEL=INFO
LOG_DIR=data/logs
LOG_SESSION_RETAIN=5

# --- Ежедневный бэкап в ЛС админам (планировщик run_bot.py) ---
BACKUP_ENABLED=true
BACKUP_HOUR_UTC=3
BACKUP_LOCAL_RETAIN=5

# --- Защита от двойных нажатий ---
BOT_ACTION_LOCK_ENABLED=true
BOT_ACTION_DEBOUNCE_SEC=0.5
BOT_ACTION_DEBOUNCE_MAX_ENTRIES=5000
PROMO_REDEEM_COOLDOWN_SEC=3.0

# --- Режимы запуска ---
# Одна команда (два процесса): python run_all.py
# Или отдельно: python app.py + python run_bot.py
# Или один процесс: START_BOT_IN_WEBAPP=true, затем python app.py
TEST_MODE=false
START_BOT_IN_WEBAPP=false

# Опасные операции в /admin → «Отладка» (сброс БД и т.п.)
# Автосинк нод: /admin → Ноды (без ALLOW_DEBUG_ADMIN)
# В продакшене оставьте false
ALLOW_DEBUG_ADMIN=false